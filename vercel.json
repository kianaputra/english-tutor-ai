{
  "buildCommand": "cd client && pnpm install && pnpm build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "devCommand": "cd client && pnpm dev",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
